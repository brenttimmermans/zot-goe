---
import ThemeToggle from "./Theme/Toggle.astro";

const currentPath = Astro.url.pathname;

const links = [
  { label: "Home", href: "/" },
  { label: "Projects", href: "/projects" },
  { label: "Contact", href: "/contact" },
];

const baseLinkClass = "px-2 py-2 rounded transition-colors";

function isActive(href: string): boolean {
  if (href === "/") return currentPath === "/";
  return currentPath.startsWith(href);
}
---

<nav class="sticky top-0 z-50 bg-bg/80 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-6 py-4 flex flex-col md:flex-row items-center gap-4 md:justify-between">
    <a href="/" class="text-xl font-bold text-heading">ZOT GOE</a>
    <div class="flex flex-col md:flex-row items-center gap-2 md:gap-8 text-center">
      {links.map((link) => (
        <a
          href={link.href}
          class={
            isActive(link.href)
              ? `${baseLinkClass} text-heading font-medium`
              : `${baseLinkClass} text-muted hover:text-accent`
          }
        >
          {link.label}
        </a>
      ))}
      <ThemeToggle />
    </div>
  </div>
</nav>
